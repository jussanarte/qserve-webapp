# =========================================================
# UNIVERSAL GITIGNORE
# Stack:
# - PHP 8 / Laravel / PHP Puro
# - Angular
# - MySQL / XAMPP
# - VS Code
# =========================================================

# =========================================================
# 1. ENV / SECURITY / LOGS
# =========================================================

# Environment files
.env
.env.*
!.env.example

# Secrets / keys
*.pem
*.key
*.crt
*.p12
*.pfx

# Logs
*.log
logs/

# =========================================================
# 2. PHP / COMPOSER
# =========================================================

# Composer dependencies
vendor/

# Composer executable
composer.phar

# PHP cache / temp
*.cache
.phpunit.result.cache

# PHPUnit
.phpunit.cache/

# =========================================================
# 3. LARAVEL
# =========================================================

# Laravel storage
storage/*.key
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/testing/*
storage/framework/views/*

# Laravel generated
bootstrap/cache/*.php

# =========================================================
# 4. ANGULAR / NODE
# =========================================================

# Dependencies
node_modules/

# Angular cache
.angular/
.angular/cache/

# Build outputs
dist/
out-tsc/
tmp/
coverage/

# Vite / cache
.vite/

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript cache
*.tsbuildinfo

# =========================================================
# 5. CSS / SASS / TAILWIND
# =========================================================

# Sass
.sass-cache/

# Tailwind
.tailwindcss/

# Source maps
*.css.map
*.js.map

# =========================================================
# 6. DATABASE / XAMPP
# =========================================================

# Database dumps
*.sql
*.sql.bak
*.sqlite
*.sqlite3
*.db

# XAMPP / Apache / phpMyAdmin
apache/logs/
mysql/data/
phpmyadmin/config.inc.php

# =========================================================
# 7. TESTS / REPORTS
# =========================================================

# Coverage
coverage/
.nyc_output/

# Screenshots
__screenshots__/
playwright-report/
test-results/

# =========================================================
# 8. IDE / EDITORS
# =========================================================

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains
.idea/

# Workspace
*.code-workspace

# Sublime
*.sublime-workspace
*.sublime-project

# Vim
*.swp
*.swo

# History
.history/

